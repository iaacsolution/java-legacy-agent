# Copier en .env (jamais commité, voir .gitignore) et remplir les valeurs réelles.
# Générer des valeurs aléatoires, par ex. : openssl rand -base64 24 | tr -d '=+/' | cut -c1-24

# Clé API Anthropic (priorité 2 dans LlmModelFactory si pas de GPU)
ANTHROPIC_API_KEY=

# Token Hugging Face (pull de modèle vLLM)
HF_TOKEN=

# Admin Grafana (dashboards agent, port 3003)
GF_ADMIN_PASSWORD=

# Admin Airflow (orchestration, port 8083) — mot de passe distinct de Grafana
AIRFLOW_ADMIN_PASSWORD=
# Clé de signature de session Airflow (Flask secret_key) — 32+ octets aléatoires
AIRFLOW_SECRET_KEY=
